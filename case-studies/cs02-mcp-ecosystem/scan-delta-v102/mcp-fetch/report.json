                  "type": [
                    "number",
                    "string"
                  ]
                },
                {
                  "type": "number",
                  "exclusiveMinimum": 0,
                  "maximum": 1000000
                }
              ],
              "default": 20000
            },
            "startIndex": {
              "allOf": [
                {
                  "type": [
                    "number",
                    "string"
                  ]
