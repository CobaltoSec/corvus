                  "security",
                  "mcp",
                  "owasp"
                ]
              }
            },
            {
              "id": "CORVUS-EXT03",
              "name": "EXT03",
              "shortDescription": {
                "text": "EXT03"
              },
              "helpUri": "https://github.com/CobaltoSec/corvus",
              "properties": {
                "tags": [
                  "security",
                  "mcp",
                  "owasp"
                ]
              }
            },
            {
              "id": "CORVUS-EXT01",
              "name": "EXT01",
              "shortDescription": {
                "text": "EXT01"
              },
              "helpUri": "https://github.com/CobaltoSec/corvus",
              "properties": {
                "tags": [
                  "security",
                  "mcp",
                  "owasp"
                ]
              }
            },
            {
              "id": "CORVUS-MCP07",
              "name": "MCP07",
              "shortDescription": {
                "text": "MCP07"
              },
              "helpUri": "https://github.com/CobaltoSec/corvus",
              "properties": {
                "tags": [
                  "security",
                  "mcp",
                  "owasp"
                ]
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "CORVUS-MCP04",
          "level": "error",
          "message": {
            "text": "Supply Chain \u2014 '@modelcontextprotocol/sdk' has high vulnerability (no CVE assigned). Package '@modelcontextprotocol/sdk' (dependency of 'mcp-server-docker') has a known high vulnerability. Solo aplicable a servidores npm v\u00eda stdio. HTTP transport: no analizable."
          }
        },
        {
          "ruleId": "CORVUS-MCP04",
          "level": "warning",
          "message": {
            "text": "Supply Chain \u2014 'uuid' has moderate vulnerability (no CVE assigned). Package 'uuid' (dependency of 'mcp-server-docker') has a known moderate vulnerability. Solo aplicable a servidores npm v\u00eda stdio. HTTP transport: no analizable."
          }
        },
        {
          "ruleId": "CORVUS-EXT03",
          "level": "error",
          "message": {
            "text": "Shadow Tool \u2014 'run_command' conflicts with a high-value built-in name. Tool 'run_command' uses a name commonly associated with built-in or high-privilege operations. A malicious server could register this tool to shadow legitimate tools and intercept LLM actions."
          },
          "locations": [
            {
              "logicalLocations": [
                {
                  "name": "run_command",
                  "kind": "function"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "CORVUS-EXT03",
          "level": "error",
          "message": {
            "text": "Shadow Tool \u2014 'run_command' description reveals arbitrary execution intent. Tool 'run_command' description contains keywords associated with arbitrary command or shell execution. This may enable sandbox escape or privilege escalation."
          },
          "locations": [
            {
              "logicalLocations": [
                {
                  "name": "run_command",
                  "kind": "function"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "CORVUS-EXT01",
          "level": "note",
          "message": {
            "text": "'run_command.command' silently accepts wrong type. Expected type 'string', sent int value '12345' \u2014 no error returned."
          },
          "locations": [
            {
              "logicalLocations": [
                {
                  "name": "run_command",
                  "kind": "function"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "CORVUS-EXT01",
          "level": "note",
          "message": {
            "text": "'run_command' accepts undeclared extra fields. Tool accepted arguments containing '__proto__' without error."
          },
          "locations": [
            {
              "logicalLocations": [
                {
                  "name": "run_command",
                  "kind": "function"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "CORVUS-MCP07",
          "level": "warning",
          "message": {
            "text": "initialize accepts protocol version downgrade. The server accepted initialize with arbitrary protocol versions: ['9999-99-99', '2030-01-01', '1.0', '2024-01-01', '\"\"', '0.1']. The server also accepted far-future versions, indicating no version validation at all. Servers should reject versions outside their supported range to prevent feature-downgrade attacks."
          }
        },
        {
          "ruleId": "CORVUS-EXT01",
          "level": "warning",
          "message": {
            "text": "Null request ID accepted \u2014 JSON-RPC spec violation. The server accepted a request with id=null and returned a result. Per JSON-RPC 2.0, null IDs are reserved for notifications (no response expected). Accepting them may cause response routing bugs in complex orchestration scenarios."
          }
        },
        {
          "ruleId": "CORVUS-EXT01",
          "level": "note",
          "message": {
            "text": "Protocol crash \u2014 string params caused server disconnect. Sending a tools/call request where params is a string (not an object) caused the server to crash or disconnect. The JSON-RPC spec requires params to be an array or object."
          }
        }
      ],
      "invocations": [
        {
          "executionSuccessful": true,
          "commandLine": "corvus scan --transport stdio"
        }
      ]
    }
  ]
}