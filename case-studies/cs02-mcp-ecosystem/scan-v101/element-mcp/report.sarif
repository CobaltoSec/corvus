      "results": [
        {
          "ruleId": "CORVUS-MCP03",
          "level": "warning",
          "message": {
            "text": "Excessive description length in 'element-search'. Description is 2277 chars (limit 1000). May contain hidden content."
          },
          "locations": [
            {
              "logicalLocations": [
                {
                  "name": "element-search",
                  "kind": "function"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "CORVUS-EXT01",
          "level": "warning",
          "message": {
            "text": "'element-search' accepts missing required fields. Tool succeeded with empty arguments despite required: ['query']"
          },
          "locations": [
            {
              "logicalLocations": [
                {
                  "name": "element-search",
                  "kind": "function"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "CORVUS-EXT01",
          "level": "note",
          "message": {
            "text": "'element-search.query' silently accepts wrong type. Expected type 'string', sent NoneType value 'None' \u2014 no error returned."
          },
          "locations": [
            {
              "logicalLocations": [
                {
                  "name": "element-search",
                  "kind": "function"
                }
              ]
            }
          ]
        },
        {
          "ruleId": "CORVUS-EXT01",
          "level": "note",
          "message": {
            "text": "'element-search' accepts undeclared extra fields. Tool accepted arguments containing '__proto__' without error."
          },
          "locations": [
            {
              "logicalLocations": [
                {
                  "name": "element-search",
                  "kind": "function"
                }
              ]
            }
          ]
        },
        {
